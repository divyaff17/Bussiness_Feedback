# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and update values

# JWT Secret (Generate a strong random string for production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Port
PORT=8080

# Supabase Configuration (Get from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend URL (CRITICAL for QR code generation)
# This is the URL where your frontend is deployed
# DEVELOPMENT: http://localhost:8000
# PRODUCTION: https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
